module-type-Foldable/index.html\">Soteria_std.Sigs.Foldable</a>)</span>\u000A  <span class=\"arrow\">&#45;&gt;</span>\u000A  <span><span><span class=\"type-var\">'elem</span> <span class=\"xref-unresolved\">M.t</span></span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span class=\"label\">f</span>:<span>(<span><span class=\"type-var\">'elem</span> <span class=\"arrow\">&#45;&gt;</span></span> <span>unit <a href=\"#type-t\">t</a></span>)</span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span>unit <a href=\"#type-t\">t</a></span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec value anchored\" id=\"val-iter_list\"><a href=\"#val-iter_list\" class=\"anchor\"></a><code><span><span class=\"keyword\">val</span> iter_list : <span><span><span class=\"type-var\">'elem</span> list</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span class=\"label\">f</span>:<span>(<span><span class=\"type-var\">'elem</span> <span class=\"arrow\">&#45;&gt;</span></span> <span>unit <a href=\"#type-t\">t</a></span>)</span> <span class=\"arrow\">&#45;&gt;</span></span> <span>unit <a href=\"#type-t\">t</a></span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec value anchored\" id=\"val-iter_iter\"><a href=\"#val-iter_iter\" class=\"anchor\"></a><code><span><span class=\"keyword\">val</span> iter_iter : <span><span><span class=\"type-var\">'elem</span> <span class=\"xref-unresolved\">Iter</span>.t</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span class=\"label\">f</span>:<span>(<span><span class=\"type-var\">'elem</span> <span class=\"arrow\">&#45;&gt;</span></span> <span>unit <a href=\"#type-t\">t</a></span>)</span> <span class=\"arrow\">&#45;&gt;</span></span> <span>unit <a href=\"#type-t\">t</a></span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec value anchored\" id=\"val-map_m\"><a href=\"#val-map_m\" class=\"anchor\"></a><code><span><span class=\"keyword\">val</span> map_m : \u000A  <span>(<span class=\"keyword\">module</span> M : <a href=\"../../Soteria_std/Sigs/module-type-Foldable/index.html\">Soteria_std.Sigs.Foldable</a>)</span>\u000A  <span class=\"arrow\">&#45;&gt;</span>\u000A  <span><span><span class=\"type-var\">'elem</span> <span class=\"xref-unresolved\">M.t</span></span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span class=\"label\">f</span>:<span>(<span><span class=\"type-var\">'elem</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span class=\"type-var\">'a</span> <a href=\"#type-t\">t</a></span>)</span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span><span class=\"type-var\">'a</span> list</span> <a href=\"#type-t\">t</a></span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec value anchored\" id=\"val-map_list\"><a href=\"#val-map_list\" class=\"anchor\"></a><code><span><span class=\"keyword\">val</span> map_list : <span><span><span class=\"type-var\">'elem</span> list</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span class=\"label\">f</span>:<span>(<span><span class=\"type-var\">'elem</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span class=\"type-var\">'a</span> <a href=\"#type-t\">t</a></span>)</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span><span class=\"type-var\">'a</span> list</span> <a href=\"#type-t\">t</a></span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec value anchored\" id=\"val-map_iter\"><a href=\"#val-map_iter\" class=\"anchor\"></a><code><span><span class=\"keyword\">val</span> map_iter : <span><span><span class=\"type-var\">'elem</span> <span class=\"xref-unresolved\">Iter</span>.t</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span class=\"label\">f</span>:<span>(<span><span class=\"type-var\">'elem</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span class=\"type-var\">'a</span> <a href=\"#type-t\">t</a></span>)</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span><span class=\"type-var\">'a</span> list</span> <a href=\"#type-t\">t</a></span></span></code></div></div></details></div></details></div><div class=\"odoc-spec\"><div class=\"spec value anchored\" id=\"val-assert_or_error\"><a href=\"#val-assert_or_error\" class=\"anchor\"></a><code><span><span class=\"keyword\">val</span> assert_or_error : \u000A  <span><span><a href=\"argument-1-Sol/Value/index.html#type-sbool\">Value.sbool</a> <a href=\"argument-1-Sol/Value/index.html#type-t\">Value.t</a></span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span class=\"type-var\">'err</span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span><span>(unit, <span class=\"type-var\">'err</span>, <span class=\"type-var\">'f</span>)</span> <a href=\"../../Soteria_std/Compo_res/index.html#type-t\">Soteria.Soteria_std.Compo_res.t</a></span> <a href=\"#type-t\">t</a></span></span></code></div><div class=\"spec-doc\"><p><code>assert_or_error guard err</code> asserts <code>guard</code> is true, and otherwise returns <code>Compo_res.Error err</code>. Biased towards the assertion being <code>false</code> to reduce SAT-checks.</p><p>This is provided as a utility, and is equivalent to</p><pre class=\"language-ocaml\"><code>branch_on (not guard)\u000A  ~then_:(fun () -&gt; return (Compo_res.error err))\u000A  ~else_:(fun () -&gt; return (Compo_res.ok ()))</code></pre></div></div><div class=\"odoc-spec\"><div class=\"spec value anchored\" id=\"val-some_or_give_up\"><a href=\"#val-some_or_give_up\" class=\"anchor\"></a><code><span><span class=\"keyword\">val</span> some_or_give_up : <span>string <span class=\"arrow\">&#45;&gt;</span></span> <span><span><span class=\"type-var\">'a</span> option</span> <span class=\"arrow\">&#45;&gt;</span></span> <span><span class=\"type-var\">'a</span> <a href=\"#type-t\">t</a></span></span></code></div><div class=\"spec-doc\"><p>If the given option is None, gives up execution, otherwise continues, unwrapping the option.</p></div></div><div class=\"odoc-spec\"><div class=\"spec module anchored\" id=\"module-Syntax\"><a href=\"#module-Syntax\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Syntax/index.html\">Syntax</a></span><span> : <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec module anchored\" id=\"module-Producer\"><a href=\"#module-Producer\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Producer/index.html\">Producer</a></span><span> : <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div></div><div class=\"odoc-spec\"><div class=\"spec module anchored\" id=\"module-Consumer\"><a href=\"#module-Consumer\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Consumer/index.html\">Consumer</a></span><span> : <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div></div></details></div><div class=\"odoc-spec\"><div class=\"spec module anchored\" id=\"module-Solver_pool\"><a href=\"#module-Solver_pool\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Solver_pool/index.html\">Solver_pool</a></span><span> : <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div><div class=\"spec-doc\"><p>A Symex runs in a pooled solver environment. This module exposes some information about the solver pool.</p></div></div><div class=\"odoc-spec\"><div class=\"spec value anchored\" id=\"val-run\"><a href=\"#val-run\" class=\"anchor\"></a><code><span><span class=\"keyword\">val</span> run : \u000A  <span><span class=\"optlabel\">?flamegraph</span>:<span>string <a href=\"../../Soteria_std/Effects/Bookkeeping/index.html#type-mode\">Soteria.Soteria_std.Effects.Bookkeeping.mode</a></span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span class=\"optlabel\">?stats</span>:<span>unit <a href=\"../../Soteria_std/Effects/Bookkeeping/index.html#type-mode\">Soteria.Soteria_std.Effects.Bookkeeping.mode</a></span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span class=\"optlabel\">?fuel</span>:<a href=\"../Fuel_gauge/index.html#type-t\">Fuel_gauge.t</a> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span class=\"label\">mode</span>:<a href=\"../Approx/index.html#type-t\">Approx.t</a> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span><span class=\"type-var\">'a</span> <a href=\"#type-t\">t</a></span> <span class=\"arrow\">&#45;&gt;</span></span>\u000A  <span><span>(<span class=\"type-var\">'a</span> * <span><a href=\"argument-1-Sol/Value/Expr/index.html#type-t\">Value.Expr.t</a> list</span>)</span> list</span></span></code></div><div class=\"spec-doc\"><p><code>run ~mode p</code> actually performs symbolic execution of the symbolic process <code>p</code> and returns a list of obtained branches which capture the outcome together with a path condition that is a list of boolean symbolic values.</p><p>The <code>mode</code> parameter is used to specify whether execution should be done in an under-approximate (<a href=\"../Approx/index.html#type-t.UX\"><code>Symex.Approx.t.UX</code></a>) or an over-approximate (<a href=\"../Approx/index.html#type-t.OX\"><code>Symex.Approx.t.OX</code></a>) manner. Users may optionally pass a <a href=\"../Fuel_gauge/index.html#type-t\" title=\"Fuel_gauge.t\">fuel gauge</a> to limit execution depth and breadth.</p><p>This function also takes a number of optional parameters to configure how the execution is performed and what information is collected during execution:</p><ul><li><code>fuel</code> receives a <a href=\"../Fuel_gauge/index.html#type-t\" title=\"Fuel_gauge.t\">fuel gauge</a> to limit execution depth and breadth. By default, the fuel is infinite.</li><li><code>stats</code> specifies whether statistics about the execution are already handled outside the function (see <a href=\"../../Stats/As_ctx/index.html#val-with_\"><code>Stats.As_ctx.with_</code></a>) or should be handled and ignored by this function (default).</li><li><code>flamegraph</code> specifies whether a flamegraph should be created from this symbolic process or if it should be ignored (default). The value passed in the <a href=\"../../Soteria_std/Effects/Bookkeeping/index.html#type-mode.Dump\" title=\"Soteria.Soteria_std.Effects.Bookkeeping.mode.Dump\"><code>Dump</code></a> variant is the name of the created file (while the <a href=\"../../Profiling/Config/index.html\" title=\"Profiling.Config\">configuration</a> for flamegraphs specifies the directory in which flamegraphs are saved).</li></ul><ul class=\"at-tags\"><li class=\"raises\"><span class=\"at-tag\">raises</span> <a href=\"../index.html#exception-Gave_up\"><code>Symex.Gave_up</code></a> <p>if the symbolic process calls <code>give_up</code> and the mode is <a href=\"../Approx/index.html#type-t.OX\"><code>Symex.Approx.t.OX</code></a>. Prefer using <a href=\"Result/index.html#val-run\"><code>Result.run</code></a> when possible.</p></li></ul></div></div><div class=\"odoc-spec\"><div class=\"spec module anchored\" id=\"module-Result\"><a href=\"#module-Result\" class=\"anchor\"></a><code><span><span class=\"keyword\">module</span> <a href=\"Result/index.html\">Result</a></span><span> : <span class=\"keyword\">sig</span> ... <span class=\"keyword\">end</span></span></code></div></div>"}