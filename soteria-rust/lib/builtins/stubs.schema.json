{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stubs.schema.json",
  "title": "Stubs configuration",
  "description": "Configures functions to be stubbed out during analysis, grouped by category.",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "_comment": { "$ref": "#/$defs/comment" }
  },
  "additionalProperties": {
    "oneOf": [
      {
        "type": "array",
        "items": { "$ref": "#/$defs/entry" }
      },
      { "$ref": "#/$defs/category_object" }
    ]
  },
  "$defs": {
    "pattern": {
      "type": "string",
      "description": "A fully-qualified Rust path using '::' separators. Use '_' for anonymous impl blocks.",
      "pattern": "^([a-zA-Z0-9_]+::)*[a-zA-Z0-9_]+$"
    },
    "extra_arg": {
      "type": "string",
      "description": "Additional metadata to pass to the stub.",
      "enum": ["fun_exec", "sig", "types"]
    },
    "category_object": {
      "type": "object",
      "required": ["patterns"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "$ref": "#/$defs/comment" },
        "patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/entry" },
          "required": true,
          "description": "Patterns for functions to stub out in this category."
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Cargo dependency lines appended verbatim to the [dependencies] section of the generated crate."
        },
        "code": {
          "type": "string",
          "description": "Code to include in the dummy crate's main function (e.g. use declarations to make items visible)."
        },
        "features": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Cargo features to enable for the generated crate."
        }
      }
    },
    "entry": {
      "oneOf": [
        { "$ref": "#/$defs/pattern" },
        {
          "type": "object",
          "required": ["pattern"],
          "additionalProperties": false,
          "properties": {
            "pattern": { "$ref": "#/$defs/pattern" },
            "extra_args": {
              "type": "array",
              "items": { "$ref": "#/$defs/extra_arg" },
              "uniqueItems": true
            }
          }
        }
      ]
    },
    "comment": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    }
  }
}
