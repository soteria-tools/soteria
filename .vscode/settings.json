{
  "ocaml.sandbox": {
    "kind": "opam",
    "switch": "${workspaceFolder:soteria}"
  },
  "makefile.configureOnOpen": false,
  "files.associations": {
    "*.t": "cram"
  },
  "[perl]": {
    "editor.formatOnSave": false,
    "files.trimTrailingWhitespace": false,
    "files.insertFinalNewline": false
  }
}